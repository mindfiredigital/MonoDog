MONODOG_DATABASE_PATH=file:/app/data/monodog.db
DATABASE_URL=file:/app/data/monodog.db
MONODOG_SERVER_HOST=0.0.0.0
MONODOG_SERVER_PORT=4000
MONODOG_DASHBOARD_HOST=0.0.0.0
MONODOG_DASHBOARD_PORT=3010
CORS_ORIGINS=http://localhost:3010,http://127.0.0.1:3010
MONODOG_PUBLIC_API_PORT=4000
MONODOG_PUBLIC_DASHBOARD_PORT=3010
GITHUB_REDIRECT_URI=http://localhost:3010/auth/callback
# Default uses a named volume. To use a host bind mount instead, uncomment:
# MONODOG_DATA_MOUNT=./.docker-data:/app/data
