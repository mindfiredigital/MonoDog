    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@monodog/utils": "1.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4",
    "prisma": "^5.7.0"
  },
  "peerDependencies": {}
}
