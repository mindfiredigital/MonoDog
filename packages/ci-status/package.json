{
  "name": "@monodog/ci-status",
  "version": "1.1.5",
  "description": "CI/CD status manager for monorepo packages",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
