{
  "name": "@mindfiredigital/monorepo-scanner",
  "version": "1.0.11",
  "description": "Monorepo scanner for analyzing packages, dependencies, and health",
  "keywords": [
    "monorepo-scanner",
    "monorepo",
    "package-analyzer",
    "dependency-scanner",
    "monorepo-health",
    "pnpm",
    "turborepo",
    "mindfiredigital"
  ],
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run --fileParallelism=false",
    "clean": "rimraf dist node_modules/.cache",
    "lint": "eslint ."
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@mindfiredigital/utils": "1.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4",
    "prisma": "^5.7.0"
  },
  "peerDependencies": {}
}
