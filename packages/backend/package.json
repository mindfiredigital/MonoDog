{
  "name": "@mindfiredigital/monodog",
  "version": "1.5.8",
  "description": "Backend API server for monodog monorepo dashboard",
  "private": true,
  "license": "MIT",
  "bin": {
    "monodog-cli": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/run-db.ts tsx watch src/serve-dev.ts",
    "start": "tsx index.ts",
    "prepublishOnly": "pnpm run build && pnpm --dir apps/dashboard run build",
    "build": "rimraf dist && tsc -p tsconfig.json",
    "prestart": "npm run build",
    "cli": "pnpm run build && node dist/cli.js",
    "clean": "rimraf dist node_modules/.cache",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:url": "node dist/get-db-url.js",
    "generate": "tsx src/run-db.ts prisma generate",
    "migrate": "tsx src/run-db.ts prisma migrate dev",
    "serve": "tsx src/run-db.ts node dist/cli.js --serve --root ../../",
    "test": "vitest run"
  },
  "dependencies": {
    "@monodog/ci-status": "1.1.5",
    "@monodog/monorepo-scanner": "1.0.9",
    "@monodog/utils": "1.0.2",
    "@prisma/client": "^5.7.0",
    "body-parser": "^1.20.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "init": "^0.1.2",
    "morgan": "^1.10.1",
    "prisma": "^5.22.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.10.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "cross-env": "^10.1.0",
    "ts-node": "^10.0.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.8",
    "vitest": "^4.1.4"
  }
}
