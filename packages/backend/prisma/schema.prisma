generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- MONOREPO DATA MODEL ---

/// Represents a single package within the monorepo, based on the pnpm/package.json data.
model Package {
  // Primary Key and Identity Field (using the package name as the unique ID)
  // Example: '@mindfiredigital/dashboard'
  name String @id @unique

  // Core Package Metadata
  version String
  type    String // e.g., 'app', 'package'

  // Timestamps
  createdAt   DateTime @default(now())
  lastUpdated DateTime @default(now())

  // Key Metrics and Relationships
  dependencies String? // The total number of direct dependencies
  // Manual Serialization Required: Stores a JSON array string of maintainers, e.g., '["team-frontend"]'
  maintainers  String
  // Manual Serialization Required: Stores a JSON array string of tags, e.g., '["core", "ui"]'
  path         String // The relative path in the file system, e.g., 'apps/dashboard'

  // Descriptions and Configuration
  description String
  license     String
  repository  String?

  // Manual Serialization Required: Stores the scripts object as a JSON string
  // Example: '{"dev": "vite", "build": "tsc && vite build"}'
  scripts String?
  status  String  @default("")

  devDependencies  String?
  peerDependencies String?
  dependenciesInfo DependencyInfo[]
  commits          Commit[]
  packageHealth    PackageHealth?
  activityLogs      ActivityLog[]
  scheduledReleases ScheduledRelease[]
}

model DependencyInfo {
  name        String
  packageName String
  version     String
  type        String  @default("")
  status      String  @default("")
  latest      String?
  outdated    Boolean @default(false)
  package     Package @relation(fields: [packageName], references: [name])

  @@unique([name, packageName]) // Composite unique constraint
}

model Commit {
  hash        String    @id
  message     String
  author      String
  date        DateTime?
  type        String
  packageName String
  package     Package   @relation(fields: [packageName], references: [name])
}



model PackageHealth {
  id                   Int      @id @default(autoincrement())
  packageName          String   @unique
  packageOverallScore  Float
  packageBuildStatus   String
  packageTestCoverage  Float?
  packageLintStatus    String
  packageSecurity      String    // Changed from securityAudit to packageSecurity
  packageDependencies  String    // Changed from dependencies to packageDependencies
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  package              Package   @relation(fields: [packageName], references: [name])

  @@map("package_health")
}

model ReleasePipeline {
  id                String   @id @default(cuid())
  releaseVersion    String
  packageName       String
  owner             String
  repo              String
  workflowId        String
  workflowName      String
  workflowPath      String?
  triggerType       String
  triggeredBy       String
  triggeredAt       DateTime
  currentStatus     String
  currentConclusion String?
  lastRunId         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  auditLogs PipelineAuditLog[]

  @@index([owner, repo, workflowId, triggeredAt])
  @@index([releaseVersion, packageName])
  @@map("release_pipeline")
}

model PipelineAuditLog {
  id           String          @id @default(cuid())
  pipelineId   String
  userId       Int
  username     String
  action       String
  resourceType String
  resourceId   String
  resourceName String
  details      String
  timestamp    DateTime        @default(now())
  status       String
  errorMessage String?

  pipeline ReleasePipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([pipelineId, timestamp])
  @@index([userId, timestamp])
  @@map("pipeline_audit_log")
}

model Session {
  id           String          @id @default(cuid())
  sessionToken String          @unique
  userId       Int
  login        String
  accessToken  String
  userData     String   
  permission   String?  
  expiresAt    DateTime
  createdAt    DateTime         @default(now())

  @@map("session")
}

model ActivityLog {
  id          String            @id @default(cuid())
  type        String
  packageName String
  message     String
  timestamp   DateTime          @default(now())
  metadata    String? 
  package     Package           @relation(fields: [packageName], references: [name], onDelete: Cascade)

  @@index([packageName, timestamp])
  @@map("activity_log")
}

model ScheduledRelease {
  id              String        @id @default(cuid())
  releaseVersion  String
  packageName     String
  scheduledAt     DateTime
  status          String        @default("pending")
  triggeredBy     String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  package         Package       @relation(fields: [packageName], references: [name], onDelete: Cascade)

  @@index([packageName, status])
  @@map("scheduled_release")
}
